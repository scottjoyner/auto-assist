# AssistX local deployment template. Keep real values in .env only.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=assistx

REDIS_URL=redis://redis:6379/0
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
API_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:8000

PAPERCLIP_API_URL=http://host.docker.internal:3100/api
PAPERCLIP_API_TOKEN=
PAPERCLIP_WORKSPACE_ID=
PAPERCLIP_AGENT_ID=Hermes Agent
PAPERCLIP_WEBHOOK_SECRET=
VOICE_WEBHOOK_SECRET=

WS_AUTH_REQUIRED=1
WS_AUTH_TOKEN=

LLM_BACKEND=openai
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# ---- Overlay integration (auto-router / auto-assign) ----
ASSISTX_OVERLAY_MODE=direct
AUTO_ROUTER_BASE_URL=
AUTO_ASSIGN_BASE_URL=
AUTO_ROUTER_HEALTH_PATH=/health
AUTO_ASSIGN_HEALTH_PATH=/health

# Optional advisory draft endpoint (for example, a small Tailnet LM Studio node).
# Keep this separate from the main inference and Paperclip/Hermes execution path.
DRAFT_MODEL_BASE_URL=http://scotts-macbook-air.tailcb8954.ts.net:1234/v1
DRAFT_MODEL_NAME=qwen3.5-0.8b-claude-4.6-opus-reasoning-distilled
DRAFT_MODEL_API_KEY=
DRAFT_MODEL_TIMEOUT_S=20

CACHE_PATH=/app/.assistx_cache.sqlite
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
