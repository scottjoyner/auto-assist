# ===== AssistX Configuration Template =====
# Copy to .env (same directory) and fill in secrets.
# .env is gitignored; keep secrets there.

# ---- Neo4j ----
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=assistx

# ---- LLM Backend ----
# "openai" (LM Studio / OpenAI API) or "ollama"
LLM_BACKEND=openai
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=not-needed
LLM_TIMEOUT_S=45
TASK_WALLCLOCK_S=600
LLM_MODEL=refinedtoolcallv5-3b
EMBED_MODEL=nomic-embed-text

# ---- Circuit Breaker (LLM fail protection) ----
LLM_CB_FAIL_THRESHOLD=9999
LLM_CB_OPEN_SECONDS=0

# ---- Per-node speed tracking ----
# Nodes > 3x slower than fleet median are skipped.
LLM_NODE_SLOW_MULTIPLIER=3.0
LLM_NODE_EMA_ALPHA=0.3
LLM_NODE_REPROBE_AFTER_S=120

# ---- Redis / Queue ----
REDIS_URL=redis://redis:6379/0
WORKER_CONCURRENCY=32

# ---- Ollama (legacy) ----
OLLAMA_HOST=http://host.docker.internal:11434

# ---- API / Execution ----
CACHE_PATH=/app/.assistx_cache.sqlite
PY_MAX_SECONDS=20
PY_MAX_MEM_MB=256

# ---- Dashboard Auth ----
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# ---- Web Search ----
TAVILY_API_KEY=

# ---- OpenRouter (optional, for fallback) ----
OPENROUTER_API_KEY=

# ---- Fleet state discovery ----
FLEET_STATE_PATH=/home/scott/git/lms/fleet_state.json

# ---- Overlay / Routing ----
ASSISTX_OVERLAY_MODE=router_plus_assign
AUTO_ROUTER_BASE_URL=http://host.docker.internal:8088
AUTO_ASSIGN_BASE_URL=http://host.docker.internal:8090
HERMES_PROVIDER=assistx-router
HERMES_LM_BASE_URL=http://host.docker.internal:8088/v1
HERMES_MODEL=local/reasoning-large
HERMES_SMOKE_MODEL=refinedtoolcallv5-3b

# ---- Paperclip ----
PAPERCLIP_API_URL=http://host.docker.internal:3100/api
PAPERCLIP_API_TOKEN=
PAPERCLIP_WORKSPACE_ID=

# ---- Optional ----
ASSISTX_USER=admin
ASSISTX_PASS=change-me
CORS_ALLOW_ORIGINS=*
