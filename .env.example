# AssistX local deployment template. Keep real values in .env only.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=assistx

REDIS_URL=redis://redis:6379/0
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
API_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:8000

PAPERCLIP_API_URL=http://host.docker.internal:3100/api
PAPERCLIP_API_TOKEN=
PAPERCLIP_WORKSPACE_ID=
PAPERCLIP_AGENT_ID=Hermes Agent
PAPERCLIP_WEBHOOK_SECRET=
VOICE_WEBHOOK_SECRET=

WS_AUTH_REQUIRED=1
WS_AUTH_TOKEN=

LLM_BACKEND=openai
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

CACHE_PATH=/app/.assistx_cache.sqlite
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
