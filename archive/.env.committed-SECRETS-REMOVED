# ===== AssistX .env =====
# Copy this file to the project root as `.env` (same folder as docker-compose.yml)

# ---- Neo4j ----
NEO4J_URI=bolt://100.64.43.123:7687
NEO4J_USER=neo4j
# Change this to a strong password; must match the docker-compose Neo4j service
NEO4J_PASSWORD=<REQUIRED: inject via secret manager>
NEO4J_DATABASE=assistx

# ---- LLM Backend ----
# Backend: "openai" (LM Studio / OpenAI API) or "ollama"
LLM_BACKEND=openai
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=<REQUIRED>
# Primary model used for chat / QA
LLM_MODEL=llama3.1:8b
# Model used for embedding / similarity cache
EMBED_MODEL=nomic-embed-text

# ---- Prep / draft model (smaller local model for exploratory work) ----
DRAFT_MODEL_BASE_URL=http://scotts-macbook-air.tailcb8954.ts.net:1234/v1
DRAFT_MODEL_NAME=qwen3.5-0.8b-claude-4.6-opus-reasoning-distilled
DRAFT_MODEL_TIMEOUT_S=20

# ---- Ollama (legacy, only used if LLM_BACKEND=ollama) ----
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:2b

# ---- API / Execution ----
# SQLite cache for LLM responses inside the container
CACHE_PATH=/app/.assistx_cache.sqlite

# Sandbox limits for the Python tool
PY_MAX_SECONDS=20
PY_MAX_MEM_MB=256

# ---- Dashboard Auth ----
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# ---- Optional: Web search (Tavily). Leave empty to use DuckDuckGo.
TAVILY_API_KEY=

# ---- Redis / Queue ----
REDIS_URL=redis://redis:6379/0

API_TOKEN=           # optional; set to require x-api-token for /upload-audio
CORS_ALLOW_ORIGINS=*

# ---- Overlay Services (AssistX discovery) ----
ASSISTX_OVERLAY_MODE=router_plus_assign
AUTO_ROUTER_BASE_URL=http://host.docker.internal:8088
AUTO_ASSIGN_BASE_URL=http://host.docker.internal:8090
ASSISTX_OVERLAY_HEALTH_TIMEOUT_S=40
AUTO_ROUTER_HEALTH_PATH=/health
AUTO_ASSIGN_HEALTH_PATH=/health
AUTO_ASSIGN_SCHEDULER_ENABLED=true
AUTO_ASSIGN_DISPATCH_ENABLED=true

# ---- Hermes Adapter (task execution via auto-assign + auto-router) ----
HERMES_PROVIDER=assistx-router
HERMES_LM_BASE_URL=http://host.docker.internal:8088/v1
HERMES_MODEL=local/reasoning-large
HERMES_SMOKE_MODEL=refinedtoolcallv5-3b
AUTO_ASSIGN_BASE_URL=http://host.docker.internal:8090

# ---- Paperclip (dispatch integration) ----
PAPERCLIP_API_URL=http://host.docker.internal:3100/api
PAPERCLIP_API_TOKEN=pcp_1966f1ebc6cdb6dece320674c5a1d16ca1d37ddacc666d38<REQUIRED>
PAPERCLIP_WORKSPACE_ID=23328778-bb2e-4261-8e8e-4221021753d5
PAPERCLIP_WEBHOOK_SECRET=paperclip-dev-secret<REQUIRED>
VOICE_WEBHOOK_SECRET=5c7d2baf742009a393bd4313a295ed5c9fe183ea<REQUIRED>
WS_AUTH_REQUIRED=1
WS_AUTH_TOKEN=5bcfe645586235e3c7f9001675ee295eb199086c144ac8be81d1328eb4198ec8<REQUIRED>

WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
